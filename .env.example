# ─── Replit Auth (automatically set by Replit) ───────────────────────────────
# REPL_ID=          # Set automatically by Replit — do not set manually
# ISSUER_URL=       # Defaults to https://replit.com/oidc

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ─── Quran Foundation OAuth (optional — enables Goals & Bookmarks sync) ───────
# Credentials are obtained from https://api-docs.quran.foundation
# After registering your app, copy the values below.
QF_CLIENT_ID=
QF_CLIENT_SECRET=
# The redirect URI must exactly match what you registered with QF.
# In development this is typically: https://<your-replit-dev-domain>/api/auth/qf/callback
# If left blank, the server derives it automatically from the incoming request host.
QF_REDIRECT_URI=
